@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-4">
    <h1 class="page-title" style="font-size: 2.5rem;">&#x1F33F; Agri-Energy Connect</h1>
    <p class="page-subtitle" style="font-size: 1.1rem;">Connecting farmers with renewable energy solutions through an intuitive digital platform</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="agri-card text-center h-100">
            <div style="font-size: 2rem;">&#x1F33E;</div>
            <h5 style="color: var(--agri-brown); font-weight: 700;">For Farmers</h5>
            <p style="color: var(--agri-muted); font-size: 0.9rem;">Streamlined product management and energy solution discovery. Manage your catalog and track production.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="agri-card text-center h-100">
            <div style="font-size: 2rem;">&#x1F465;</div>
            <h5 style="color: var(--agri-brown); font-weight: 700;">For Employees</h5>
            <p style="color: var(--agri-muted); font-size: 0.9rem;">Efficient farmer relationship management and inventory oversight with powerful search and filter tools.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="agri-card text-center h-100">
            <div style="font-size: 2rem;">&#x1F331;</div>
            <h5 style="color: var(--agri-brown); font-weight: 700;">For the Industry</h5>
            <p style="color: var(--agri-muted); font-size: 0.9rem;">Sustainable connections between agriculture and renewable energy. Building a greener future through technology.</p>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="agri-card h-100">
            <div class="agri-card-title">&#x2699; Platform Features</div>
            <ul class="list-unstyled mb-0">
                <li class="py-1 border-bottom">&#x1F512; Secure role-based authentication</li>
                <li class="py-1 border-bottom">&#x1F4E6; Product catalog management</li>
                <li class="py-1 border-bottom">&#x1F50D; Advanced search and filtering</li>
                <li class="py-1 border-bottom">&#x1F4C5; Production date tracking</li>
                <li class="py-1">&#x1F4F1; Responsive design for mobile field use</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="agri-card h-100">
            <div class="agri-card-title">&#x1F4BB; Technical Highlights</div>
            <ul class="list-unstyled mb-0">
                <li class="py-1 border-bottom">Built with ASP.NET Core 9.0</li>
                <li class="py-1 border-bottom">Repository pattern for clean data access</li>
                <li class="py-1 border-bottom">SQL Server with optimized indexing</li>
                <li class="py-1 border-bottom">Docker containerized deployment</li>
                <li class="py-1">Cloud-optimized architecture</li>
            </ul>
        </div>
    </div>
</div>
