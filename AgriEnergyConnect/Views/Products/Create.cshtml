@model Product

@{
    ViewData["Title"] = "Add Product";
}

<h1 class="page-title">&#x1F33F; Add New Product</h1>
<p class="page-subtitle">Register your farm's production for our sustainable network</p>

<a asp-action="Index" class="btn btn-agri-outline mb-3">&larr; Back to Products</a>

<div class="row">
    <div class="col-md-7">
        <div class="agri-card">
            <div class="agri-card-title">&#x270F; Product Information</div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="agri-label">&#x1F4A7; Product Name</label>
                    <input asp-for="Name" class="form-control agri-input" placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="agri-label">&#x2630; Product Category</label>
                    <select asp-for="Category" class="form-select agri-input">
                        <option value="">Select a category</option>
                        <option value="Fruits">Fruits</option>
                        <option value="Vegetables">Vegetables</option>
                        <option value="Grains">Grains</option>
                        <option value="Dairy">Dairy</option>
                        <option value="Livestock">Livestock</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductionDate" class="agri-label">&#x1F4C5; Production Date</label>
                    <input asp-for="ProductionDate" type="date" class="form-control agri-input" />
                    <span asp-validation-for="ProductionDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="agri-label">&#x1F4B0; Price</label>
                    <input asp-for="Price" class="form-control agri-input" placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="agri-label">&#x1F4E6; Quantity</label>
                    <input asp-for="Quantity" class="form-control agri-input" placeholder="0" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="agri-label">&#x1F4DD; Description</label>
                    <textarea asp-for="Description" class="form-control agri-input" rows="3" placeholder="Describe your product"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-agri-green">&#x2714; Save Product</button>
                    <button type="reset" class="btn btn-agri-outline">&#x1F504; Reset</button>
                </div>

                <div class="privacy-notice">
                    &#x1F512; All product information is protected under our <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
